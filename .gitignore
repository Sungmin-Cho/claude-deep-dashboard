# Claude Code — user-local session state (not the plugin manifest)
.claude/

# Serena MCP — project memory / config
.serena/

# deep-suite runtime artifacts (generated when plugins run locally,
# including this plugin against itself)
.deep-work/
.deep-docs/
.deep-evolve/
.deep-dashboard/

# deep-review — runtime state and local review outputs
.deep-review/config.yaml
.deep-review/reports/
.deep-review/responses/
